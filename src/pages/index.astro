                        // Regular drag zooms X/Y.
                        wall.classList.add("is-curve-drag");
                        drag.view.classList.add("is-curve-drag");
                        if (Math.abs(dx) > Math.abs(dy)) {
                            wall.classList.remove("is-curve-drag-y");
                            drag.view.classList.remove("is-curve-drag-y");
                        } else {
                            wall.classList.add("is-curve-drag-y");
                            drag.view.classList.add("is-curve-drag-y");
                        }
                        // Drag delta capped at 500px so a single full-width
                        // drag can sweep the full zoom range. 1 -> 0.25 is
                        // ~280px at the X factor below.
                        const ndx = Math.max(-500, Math.min(500, dx));
                        const ndy = Math.max(-500, Math.min(500, dy));
                        // Houdini-style channel drag: drag in the direction of
                        // the axis to zoom in. ndy comes from clientY which
                        // grows downward, so drag-up is negative ndy.
                        // X zoom is OUT-only (0.25..1): drag X LEFT to grow
                        // the visible domain (zoom out, see repeats); drag X
                        // RIGHT to return to the default (zoomX=1).
                        // Y zoom is normalized (0.5..3): drag up zooms in,
                        // drag down zooms out, around the data range. Y is
                        // intentionally less sensitive than X (1.002 vs 1.005)
                        // so vertical zoom feels like a fine adjustment.
                        //
                        // Set the value directly each mousemove — no per-frame
                        // easing. The user expects the curve to follow the
                        // cursor 1:1. (A previous version lerped toward a
                        // target, which produced a visible lag during fast
                        // drags because the target kept moving ahead of the
                        // lerp.)
                        const nextZoomX = drag.zx0 * Math.pow(1.005, ndx);
                        const nextZoomY = drag.zy0 * Math.pow(1.002, -ndy);
                        broadcastView(
                            drag.view,
                            {
                                zoomX: nextZoomX,
                                zoomY: nextZoomY,
                                centerX: drag.cx0,
                                centerY: drag.cy0,
                                wrapMode: wrapMode,
                            },
                            { flash: false },
                        );
                    }
                });
                window.addEventListener("mouseup", function () {
                    if (!drag) return;
                    if (drag.moved) {
                        if (drag.kind === "size") {
                            const { minW: curMinW, rowH: curRowH } =
                                readActiveSize();
                            writeGridSize({
                                minW: isFinite(curMinW) ? curMinW : drag.minW0,
                                rowH: isFinite(curRowH) ? curRowH : drag.rowH0,
                            });
                        }
                        const swallow = function (ev: MouseEvent) {
                            ev.stopPropagation();
                            ev.preventDefault();
                            document.removeEventListener(
                                "click",
                                swallow,
                                true,
                            );
                        };
                        document.addEventListener("click", swallow, true);
                    }
                    // The zoom-view easing loop self-terminates when the
                    // current value reaches the target (within epsilon).
                    // We do not cancel the rAF here — the user expects the
                    // drag to settle smoothly after release.
                    wall.classList.remove(
                        "is-dragging",
                        "is-curve-drag",
                        "is-curve-drag-y",
                    );
                    if (drag.kind === "zoom-view" || drag.kind === "pan-view") {
                        drag.view.classList.remove(
                            "is-curve-drag",
                            "is-curve-drag-y",
                        );
                    }
                    drag = null;
                });

                // --- hover probe ------------------------------------------
                // The canvas renderer owns probe hit-testing, crosshairs,
                // and labels. We just forward the cursor position. The
                // renderer decides internally whether to show the probe
                // (based on column count) — setProbe() always tracks the
                // mouse so the custom cursor stays active even in dense
                // mode where the probe itself is suppressed.
                const updateProbe = function (
                    view: HTMLElement,
                    clientX: number,
                    clientY: number,
                ) {
                    rendererFor(view).setProbe(clientX, clientY);
                };
                const clearProbeState = function () {
                    if (hoveredView) {
                        const renderer = canvasRenderers.get(hoveredView);
                        if (renderer) renderer.clearProbe();
                        hoveredView.classList.remove(
                            "has-probe",
                            "is-probe-near",
                        );
                    }
                    hoveredView = null;
                };
                // Track the currently hovered card so that moving from one
                // card to another clears the previous card's probe (which
                // would otherwise stay at full alpha with its cursor pinned
                // to the last-known position).
                let hoveredView: HTMLElement | null = null;
                wall.addEventListener("mousemove", function (e: MouseEvent) {
                    const view = findView(e.target);
                    if (!view) {
                        clearProbeState();
                        return;
                    }
                    if (view !== hoveredView) {
                        // Cursor crossed into a new card. Clear the probe on
                        // the previous one so its cursor + probe start their
                        // disappear ramp instead of getting stuck.
                        if (hoveredView) {
                            const prev = canvasRenderers.get(hoveredView);
                            if (prev) prev.clearProbe();
                            hoveredView.classList.remove(
                                "has-probe",
                                "is-probe-near",
                            );
                        }
                        hoveredView = view;
                    }
                    updateProbe(view, e.clientX, e.clientY);
                });
                wall.addEventListener("mouseleave", clearProbeState);

                // --- click to select --------------------------------------
                grid.addEventListener("click", function (e: MouseEvent) {
                    const card = findCard(e.target);
                    if (!card) return;
                    // @ts-expect-error - e.target is EventTarget | null; closest is on Element.
                    if (e.target.closest("button, a, input")) return;
                    cards.forEach(function (c) {
                        c.classList.remove("is-selected");
                    });
                    card.classList.add("is-selected");
                });
            })();
        </script>

        <script>
            import { initSnippetPopover } from "../lib/snippetPopover";
            initSnippetPopover();
        </script>
    </body>
</html>
