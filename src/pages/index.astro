                    // when the card is small.
                    grid.setAttribute("data-cols", String(currentCols));
                    grid.querySelectorAll<HTMLElement>(
                        "[data-curve-view]",
                    ).forEach(function (view) {
                        const renderer = canvasRenderers.get(view);
                        if (renderer) renderer.setColumnCount(currentCols);
                    });
                };
                const setWallHeadCols = function (_c: number) {
                    // no-op: the scale readout was removed.
                };

                const visibleBoxFor = function (
                    def: { x: number; y: number; w: number; h: number },
                    st: CurveViewportState,
                ) {
                    const w = def.w / st.zoomX;
                    const h = def.h / st.zoomY;
                    const x = def.x + (def.w - w) * st.centerX;
                    const y = def.y + (def.h - h) * st.centerY;
