                    }
                    const zoomXStr = fmtZoom(st.zoomX);
                    const zoomYStr = fmtZoom(st.zoomY);
                    if (cached.x && cached.x.textContent !== zoomXStr) {
                        cached.x.textContent = zoomXStr;
                    }
                    if (cached.y && cached.y.textContent !== zoomYStr) {
                        cached.y.textContent = zoomYStr;
                    }
