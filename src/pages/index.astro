                        view.setAttribute("data-zoom-x", attrX);
                        view.setAttribute("data-zoom-y", attrY);
                    }
                };

                // --- shared viewport scaling ------------------------------
                let wrapMode: CurveWrapMode = "clamp";
                const wrapBtn = document.getElementById(
                    "wrap-toggle",
                ) as HTMLElement | null;
                const wrapState = document.getElementById(
                    "wrap-toggle-state",
                ) as HTMLElement | null;
                try {
                    const w = localStorage.getItem(WRAP_KEY);
                    if (
                        w === "repeat" ||
                        w === "mirror" ||
                        w === "loop" ||
                        w === "clamp"
