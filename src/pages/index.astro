---
// ---------------------------------------------------------------------------
// index.astro
// Curvoteca's main page. Composes the persistent shell (TopBar,
// IconRail, CompareTray) around the CurveWall of all curves from
// `data/curves.ts`, plus the #copy-popover host for snippet copying.
// Owns the inline client scripts that wire up:
//   - search box, filter chips, favorites
//   - compare tray selection + localStorage + ?c= URL sync
//   - per-card viewport state (zoom/pan/wrap) with shared-view support
//   - focus / atlas / browse modes and step navigation
// This file is intentionally long: it is the single integration point
// for the home page's interactive behavior.
// ---------------------------------------------------------------------------
import TopBar from "../components/TopBar.astro";
import IconRail from "../components/IconRail.astro";
import CurveWall from "../components/CurveWall.astro";
import CompareTray from "../components/CompareTray.astro";
import SponsorSlot from "../components/SponsorSlot.astro";
import CombineIcon from "../components/CombineIcon.astro";
import { curves } from "../data/curves";
import { PAGER } from "../lib/curveViewportMath";
import {
    KEY_FAVORITES,
    KEY_COMPARE,
    KEY_TRAY_COLLAPSED,
    KEY_GALLERY_MODE,
    KEY_CURVE_VIEW,
    KEY_WRAP_MODE,
    KEY_GRID_SIZE,
    KEY_GRID_COLS,
    KEY_PAGER_SIZE,
} from "../lib/storageKeys";
import "../styles/colors.css";
import "../styles/font.css";
import "../styles/global.css";
import "../styles/icons.css";
import "../styles/globalfx.css";
import "../styles/viewport-colors.css";
import "../styles/gallery.css";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>
            Curvoteca - visual curve reference for animation, shading and UI
        </title>
        <meta
            name="description"
            content="Curvoteca is a dense visual reference of mathematical curves for UI, shading, animation and tooling. Browse, compare and copy equations for JS, GLSL, VEX and more."
        />
        <link rel="canonical" href="/" />
        <meta
            name="keywords"
            content="curves, easing, interpolation, animation, UI, GLSL, VEX, math, reference"
        />
        <meta
            property="og:title"
            content="Curvoteca - visual curve reference"
        />
        <meta
            property="og:description"
            content="Dense visual reference of math curves. Browse, compare, copy equations to JS, GLSL, VEX."
        />
        <meta property="og:type" content="website" />
        <meta name="twitter:card" content="summary" />
        <meta
            name="twitter:title"
            content="Curvoteca - visual curve reference"
        />
        <meta
            name="twitter:description"
            content="Dense visual reference of math curves. Browse, compare, copy equations to JS, GLSL, VEX."
        />
        <script is:inline>
            // Pre-paint: resolve persisted grid sizing from localStorage
            // and apply it to <html> as CSS variables. This prevents the
            // first-paint shift that would otherwise happen when the main
            // inline script reads localStorage and sets --card-min-w /
            // --card-row-h / --grid-cols on the grid (Lighthouse CLS).
            (function () {
                try {
                    var KEYS = {
                        gridSize: "curvoteca:grid-size",
                        gridCols: "curvoteca:grid-cols",
                    };
                    var raw = localStorage.getItem(KEYS.gridSize);
                    if (raw) {
                        var p = JSON.parse(raw);
                        if (
                            p &&
                            typeof p.minW === "number" &&
                            typeof p.rowH === "number"
                        ) {
                            document.documentElement.style.setProperty(
                                "--card-min-w",
                                p.minW + "px",
                            );
                            document.documentElement.style.setProperty(
                                "--card-row-h",
                                p.rowH + "px",
                            );
                        }
                    }
                    var c = parseInt(
                        localStorage.getItem(KEYS.gridCols) || "0",
                        10,
                    );
                    if (c >= 1 && c <= 8) {
                        document.documentElement.style.setProperty(
                            "--grid-cols",
                            "repeat(" + c + ", minmax(0, 1fr))",
                        );
                    }
                } catch (e) {
                    /* localStorage may be unavailable; fall through */
                }
            })();
        </script>
    </head>
    <body>
        <main class="app" id="app">
            <TopBar />
            <IconRail />
            <CurveWall curves={curves} />
            <CompareTray curves={curves.slice(0, 5)} />
        </main>

        <div id="view-overlay" data-view-overlay aria-hidden="true">
            <div class="view-overlay-backdrop" data-overlay-close></div>
            <div class="view-overlay-box" role="dialog" aria-modal="true">
                <button class="icon view-overlay-close" type="button" data-overlay-close aria-label="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" height="16px" viewBox="0 -960 960 960" width="16px" fill="currentColor" aria-hidden="true">
                        <path d="M480-440 288-248l-88-88 192-192-192-192 88-88 192 192 192-192 88 88-192 192 192 192-88 88-192-192Z"/>
                    </svg>
                </button>
                <div class="view-overlay-content" data-overlay-content="sponsor" aria-hidden="true">
                    <h2>Support</h2>
                    <p>
                        Curvoteca is a free, static reference — no accounts, no
                        backends, no tracking. If the curves save you time or
                        spark an idea, a small donation helps keep the project
                        growing.
                    </p>
                    <p class="section-label">What donations fund</p>
                    <ul class="sponsor-list">
                        <li>Domain, hosting, and CDN costs</li>
                        <li>Adding more curves, formats, and features</li>
                        <li>Expanding the equation library across more languages</li>
                        <li>Keeping everything free and open for everyone</li>
                    </ul>
                    <SponsorSlot />
                    <div class="pix-qr-wrap">
                        <img
                            class="pix-qr"
                            data-qr-for="buyme"
                            src="/buyme-qr-code.png"
                            alt="Buy Me a Coffee QR code"
                            width="200"
                            height="200"
                            hidden
                        />
                        <a class="qr-link" data-qr-for="buyme" href="https://buymeacoffee.com/curvoteca" target="_blank" rel="noopener noreferrer" hidden>buymeacoffee.com/curvoteca</a>
                        <img
                            class="pix-qr"
                            data-qr-for="pix"
                            src="/pixqrcode.png"
                            alt="Pix QR code for donation"
                            width="200"
                            height="200"
                            hidden
                        />
                    </div>
                    <p class="micro note">
                        No payment logic lives inside this app. Transactions
                        happen entirely on the provider sites.
                    </p>
                </div>
                <div class="view-overlay-content" data-overlay-content="about" aria-hidden="true">
                    <h2>About</h2>
                    <p>
                        A visual reference for the curve-curious. Tuning
                        animation timing? Crafting shader falloff? Building UI
                        transitions? Curvoteca lets you browse, compare, and
                        copy equations side by side.
                    </p>
                    <ul class="lang-list">
                        <li>JS</li><li>GLSL</li><li>VEX</li><li>Python</li><li>C#</li><li>Rust</li><li>C</li><li>C++</li><li>HLSL</li><li>OpenCL</li><li>Lua</li><li>Metal</li><li>WGSL</li><li>CUDA</li><li>Swift</li><li>Kotlin</li><li>TypeScript</li><li>TouchDesigner</li><li>Java</li><li>MATLAB</li><li>Dart</li><li>Julia</li><li>MEL</li><li>GDScript</li><li>Blueprint</li><li>After Effects</li><li>DCTL</li><li>CSS</li><li>Framer Motion</li><li>GSAP</li><li>Arduino</li><li>OSL</li><li>Max/MSP gen~</li><li>REAPER JSFX</li><li>Nuke</li><li>Csound</li><li>ChucK</li><li>JSON</li><li>SVG</li><li>Haskell</li><li>Fortran</li><li>R</li><li>Wolfram Language</li><li>and more</li>
                    </ul>
                    <p>
                        No accounts, no paywalls, no tracking. Just a tool made
                        by someone who needed it, shared with anyone who does
                        too. If it saves you time, donations are deeply
                        appreciated. The intention is to keep scaling it — more
                        curves, more formats, and always free.
                    </p>
                    <p class="micro note">
                        Contact: <a href="mailto:hello@curvoteca.com">hello@curvoteca.com</a>
                    </p>
                </div>
            </div>
        </div>

        <div id="copy-popover" data-copy-popover></div>

        <div class="pager" id="wall-pager" aria-label="Wall pagination">
            <div class="pager-cluster">
                <button
                    class="icon pager-btn"
                    type="button"
                    id="pager-prev"
                    title="previous page"
                    aria-label="Previous page"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        height="16px"
                        viewBox="0 -960 960 960"
                        width="16px"
                        fill="currentColor"
                        aria-hidden="true"
                    >
                        <path
                            d="M560-208 288-480l272-272 88 88-184 184 184 184-88 88Z"
                        ></path>
                    </svg>
                </button>
                <span class="pager-state" aria-live="polite">
                    <b id="pager-page">1</b><span class="pager-sep">/</span><b
                        id="pager-total">1</b
                    >
                </span>
                <button
                    class="icon pager-btn"
                    type="button"
                    id="pager-next"
                    title="next page"
                    aria-label="Next page"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        height="16px"
                        viewBox="0 -960 960 960"
                        width="16px"
                        fill="currentColor"
                        aria-hidden="true"
                    >
                        <path
                            d="M472-480 288-664l88-88 272 272-272 272-88-88 184-184Z"
                        ></path>
                    </svg>
                </button>
                <button
                    class="chip pager-size"
                    type="button"
                    id="pager-size"
                    title="cycle cards per page"
                    aria-label="Cycle cards per page"
                >
                    <span id="pager-size-val">32</span>
                </button>
                <button
                    class="link-toggle pager-compare"
                    type="button"
                    id="rail-compare"
                    title="toggle compare tray"
                    aria-label="Toggle compare tray"
                    aria-pressed="true"
                >
                    <CombineIcon size={14} class="is-compare" />
                    <span class="link-toggle-state">compare</span>
                </button>
                <button
                    class="link-toggle pager-wrap"
                    type="button"
                    id="wrap-toggle"
                    aria-pressed="false"
                    title="cycle wrap mode: clamp / repeat / mirror / loop"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        height="14px"
                        viewBox="0 -960 960 960"
                        width="14px"
                        fill="currentColor"
                        aria-hidden="true"
                    >
                        <path
                            d="M220-237q-101 0-172-71t-172-172q0-101 71-172t172-71q41 0 79 14.5t68 41.5l55 48-94 85-45-39q-13-11-29.5-17.5T220-597q-49 0-83 34t-34 83q0 49 34 83t83 34q17 0 33.5-6.5T283-387l310-280q30-27 68-41.5t79-14.5q101 0,172,71t71,172q0,101-71,172t-172,71q-41 0-79-14.5T593-293l-55-48 94-85 45 39q13 11 29.5 17.5T740-363q49 0 83-34t34-83q0-49-34-83t-83-34q-17 0-33.5 6.5T677-573L367-293q-30 27-68 41.5T220-237Z"
                        ></path>
                    </svg>
                    <span class="link-toggle-state" id="wrap-toggle-state"
                        >clamp</span
                    >
                </button>
            </div>
        </div>

        <script is:inline>
            (function () {
                const isTextSurface = function (el) {
                    if (!el) return false;
                    if (
                        el.closest &&
                        el.closest(
                            'input, textarea, [contenteditable="true"], code, pre, kbd, samp, var, .detail-snippet-code, .detail-formula, .is-selectable, .allow-select',
                        )
                    ) {
                        return true;
                    }
                    return false;
                };
                document.addEventListener("contextmenu", function (e) {
                    if (isTextSurface(e.target)) return;
                    e.preventDefault();
                });
            })();
        </script>

        <script is:inline>
            // Single document-level click dispatcher. Per-feature inline
            // scripts below register handlers via window.__appClickHandlers;
            // we iterate them in registration order so behavior matches the
            // previous (separate) listeners.
            (function () {
                window.__appClickHandlers = window.__appClickHandlers || [];
                document.addEventListener("click", function (e) {
                    const handlers = window.__appClickHandlers;
                    for (let i = 0; i < handlers.length; i += 1) {
                        try {
                            handlers[i](e);
                        } catch (err) {
                            /* ignore */
                        }
                    }
                });
            })();
        </script>

        <script is:inline>
            (function () {
                const overlay = document.getElementById("view-overlay");
                const railBtns = document.querySelectorAll("[data-rail-view]");
                if (!overlay) return;

                const openOverlay = function (view) {
                    const contents = overlay.querySelectorAll("[data-overlay-content]");
                    contents.forEach(function (c) {
                        c.setAttribute("aria-hidden", c.getAttribute("data-overlay-content") !== view ? "true" : "false");
                    });
                    overlay.setAttribute("aria-hidden", "false");
                    railBtns.forEach(function (b) {
                        b.classList.toggle("active", b.getAttribute("data-rail-view") === view);
                    });
                };

                const closeOverlay = function () {
                    overlay.setAttribute("aria-hidden", "true");
                    railBtns.forEach(function (b) {
                        b.classList.remove("active");
                    });
                };

                var hashMap = { support: "sponsor", about: "about" };
                var hashView = hashMap[window.location.hash.replace("#", "")];
                if (hashView) openOverlay(hashView);

                window.__appClickHandlers.push(function (e) {
                    const close = e.target.closest("[data-overlay-close]");
                    if (close) {
                        e.preventDefault();
                        closeOverlay();
                        return;
                    }
                    const btn = e.target.closest("[data-rail-view]");
                    if (!btn) return;
                    e.preventDefault();
                    const view = btn.getAttribute("data-rail-view");
                    if (view === "gallery") {
                        closeOverlay();
                        return;
                    }
                    openOverlay(view);
                });

                window.__appClickHandlers.push(function (e) {
                    const pixBtn = e.target.closest("[data-toggle-qr]");
                    if (!pixBtn) return;
                    e.preventDefault();
                    const key = pixBtn.getAttribute("data-toggle-qr");
                    const els = document.querySelectorAll("[data-qr-for=\"" + key + "\"]");
                    if (!els.length) return;
                    const wasHidden = els[0].hasAttribute("hidden");
                    els.forEach(function (el) {
                        if (wasHidden) {
                            el.removeAttribute("hidden");
                        } else {
                            el.setAttribute("hidden", "");
                        }
                    });
                });
            })();
        </script>

        <script
            is:inline
            define:vars={{
                KEY_FAVORITES,
                KEY_COMPARE,
                KEY_TRAY_COLLAPSED,
                KEY_GALLERY_MODE,
                KEY_CURVE_VIEW,
                KEY_WRAP_MODE,
                KEY_GRID_SIZE,
                KEY_GRID_COLS,
                KEY_PAGER_SIZE,
                PAGER_SIZES: PAGER.sizes,
                PAGER_DEFAULT_SIZE: PAGER.defaultSize,
            }}
        >
            window.KEY_FAVORITES = KEY_FAVORITES;
            window.KEY_COMPARE = KEY_COMPARE;
            window.KEY_TRAY_COLLAPSED = KEY_TRAY_COLLAPSED;
            window.KEY_GALLERY_MODE = KEY_GALLERY_MODE;
            window.KEY_CURVE_VIEW = KEY_CURVE_VIEW;
            window.KEY_WRAP_MODE = KEY_WRAP_MODE;
            window.KEY_GRID_SIZE = KEY_GRID_SIZE;
            window.KEY_GRID_COLS = KEY_GRID_COLS;
            window.KEY_PAGER_SIZE = KEY_PAGER_SIZE;
            window.PAGER_SIZES = PAGER_SIZES;
            window.PAGER_DEFAULT_SIZE = PAGER_DEFAULT_SIZE;
        </script>

        <script is:inline>
            (function () {
                const search = document.getElementById("curve-search");
                const chips = document.querySelectorAll(".chips .chip");
                const cards = document.querySelectorAll(".wall .grid .card");
                const empty = document.getElementById("wall-empty");
                const totalCountEl = document.getElementById("total-count");
                const statusFavEl = document.getElementById("status-fav");
                const statusCmpEl = document.getElementById("status-cmp");
                const favCountEl = document.getElementById("fav-count");
                const cmpCountEl = document.getElementById("cmp-count");
                const filterStateEl = document.getElementById("filter-state");
                const filterStateVal =
                    document.getElementById("filter-state-val");
                const filterStateClear =
                    document.getElementById("filter-state-clear");
                const railBtn = document.querySelector("[data-fav-filter]");

                if (!search || !cards.length) {
                    return;
                }

                if (totalCountEl)
                    totalCountEl.textContent = String(cards.length);

                // Favorites state
                const favState = { ids: [] };
                try {
                    const raw = localStorage.getItem(window.KEY_FAVORITES);
                    if (raw) favState.ids = JSON.parse(raw) || [];
                } catch (e) {}

                const persistFavs = function () {
                    try {
                        localStorage.setItem(
                            window.KEY_FAVORITES,
                            JSON.stringify(favState.ids),
                        );
                    } catch (e) {}
                };

                const state = { query: "", filter: "all", value: "" };

                const norm = function (s) {
                    return (s || "").toString().toLowerCase().trim();
                };

                const matches = function (card) {
                    const hay = norm(card.getAttribute("data-search"));
                    if (state.query) {
                        if (hay.indexOf(state.query) === -1) return false;
                    }
                    if (!state.filter || state.filter === "all") return true;
                    if (state.filter === "fav") {
                        const id = card.getAttribute("data-curve-id");
                        return favState.ids.indexOf(id) !== -1;
                    }
                    const value = norm(state.value);
                    if (!value) return true;
                    const attr =
                        state.filter === "family"
                            ? card.getAttribute("data-family")
                            : "";
                    return norm(attr) === value;
                };

                const labelForFilter = function (filter, value) {
                    if (!filter || filter === "all") return null;
                    if (filter === "fav") return "favorites";
                    if (filter === "family") return "family: " + value;
                    return filter;
                };

                const renderFilterState = function () {
                    const label = labelForFilter(state.filter, state.value);
                    if (!label) {
                        filterStateEl.classList.add("is-hidden");
                        return;
                    }
                    filterStateEl.classList.remove("is-hidden");
                    if (filterStateVal) filterStateVal.textContent = label;
                };

                const clearFilter = function () {
                    state.filter = "all";
                    state.value = "";
                    chips.forEach(function (c) {
                        c.classList.remove("active");
                    });
                    const allChip = document.querySelector(
                        '.chip[data-filter="all"]',
                    );
                    if (allChip) allChip.classList.add("active");
                    renderFilterState();
                    apply();
                };

                const apply = function () {
                    let shown = 0;
                    cards.forEach(function (card) {
                        const ok = matches(card);
                        card.classList.toggle("is-hidden", !ok);
                        if (ok) shown += 1;
                    });
                    if (empty) empty.classList.toggle("is-hidden", shown !== 0);
                    // Notify the pager so it can reset to page 1 and
                    // recompute its window against the new filter-visible
                    // set. The pager listens for this event; it does not
                    // re-run the filter.
                    try {
                        window.dispatchEvent(
                            new CustomEvent("curvoteca:filter-changed"),
                        );
                    } catch (e) {}
                };

                const renderFavs = function () {
                    const railFav = document.querySelector("[data-rail-fav]");
                    if (railFav) railFav.disabled = favState.ids.length === 0;
                    cards.forEach(function (card) {
                        const id = card.getAttribute("data-curve-id");
                        const on = favState.ids.indexOf(id) !== -1;
                        card.classList.toggle("is-fav", on);
                        const btn = card.querySelector(".fav-btn");
                        if (btn) {
                            btn.classList.toggle("is-on", on);
                            btn.setAttribute("data-label", on ? "on" : "off");
                        }
                    });
                    if (railBtn)
                        railBtn.classList.toggle(
                            "active",
                            state.filter === "fav",
                        );
                    if (favCountEl)
                        favCountEl.textContent = String(favState.ids.length);
                    if (statusFavEl)
                        statusFavEl.classList.toggle(
                            "is-on",
                            favState.ids.length > 0,
                        );
                };

                const toggleFav = function (id) {
                    const i = favState.ids.indexOf(id);
                    if (i === -1) favState.ids = favState.ids.concat([id]);
                    else
                        favState.ids = favState.ids
                            .slice(0, i)
                            .concat(favState.ids.slice(i + 1));
                    persistFavs();
                    renderFavs();
                    apply();
                };

                search.addEventListener("input", function () {
                    state.query = norm(search.value);
                    apply();
                });

                chips.forEach(function (chip) {
                    chip.addEventListener("click", function () {
                        chips.forEach(function (c) {
                            c.classList.remove("active");
                        });
                        chip.classList.add("active");
                        state.filter =
                            chip.getAttribute("data-filter") || "all";
                        state.value =
                            chip.getAttribute("data-filter-value") || "";
                        renderFilterState();
                        apply();
                    });
                });

                if (filterStateClear) {
                    filterStateClear.addEventListener("click", function (e) {
                        e.preventDefault();
                        clearFilter();
                    });
                }

                window.__appClickHandlers.push(function (e) {
                    const tog = e.target.closest("[data-fav-toggle]");
                    if (tog) {
                        e.preventDefault();
                        toggleFav(tog.getAttribute("data-fav-toggle"));
                        return;
                    }
                    if (e.target.closest("[data-fav-filter]")) {
                        const isFav = state.filter === "fav";
                        chips.forEach(function (c) {
                            c.classList.remove("active");
                        });
                        if (isFav) {
                            state.filter = "all";
                            document
                                .querySelector('.chip[data-filter="all"]')
                                .classList.add("active");
                        } else {
                            state.filter = "fav";
                            document
                                .querySelector('.chip[data-filter="fav"]')
                                .classList.add("active");
                        }
                        state.value = "";
                        renderFilterState();
                        apply();
                        renderFavs();
                    }
                });

                renderFavs();
                renderFilterState();
            })();
        </script>

        <script is:inline>
            // --- wall pager (screen-glued) ---------------------------------
            // Splits the wall's card list into fixed-size pages. Cards
            // outside the current page get `.is-paged-out` (display:none)
            // layered on top of the filter's `.is-hidden`. The pager does
            // not know about the filter — it only operates on cards the
            // filter has accepted. The filter's `curvoteca:filter-changed`
            // event resets the page to 1 and re-applies the window.
            (function () {
                const PAGER_KEY = window.KEY_PAGER_SIZE;
                const SIZES = window.PAGER_SIZES;
                const DEFAULT_SIZE = window.PAGER_DEFAULT_SIZE;
                const pagerEl = document.getElementById("wall-pager");
                const prevBtn = document.getElementById("pager-prev");
                const nextBtn = document.getElementById("pager-next");
                const sizeBtn = document.getElementById("pager-size");
                const sizeValEl = document.getElementById("pager-size-val");
                const pageEl = document.getElementById("pager-page");
                const totalEl = document.getElementById("pager-total");
                const cards = document.querySelectorAll("#wall-grid .card");
                if (!pagerEl || !prevBtn || !nextBtn || !sizeBtn) return;
                if (!cards.length) {
                    pagerEl.classList.add("is-hidden");
                    return;
                }

                // Resolve persisted size (clamp to SIZES so a stale value
                // from a future build never breaks the cycle).
                const readSize = function () {
                    try {
                        const raw = localStorage.getItem(PAGER_KEY);
                        if (!raw) return DEFAULT_SIZE;
                        const n = parseInt(raw, 10);
                        if (SIZES.indexOf(n) !== -1) return n;
                    } catch (e) {}
                    return DEFAULT_SIZE;
                };
                const writeSize = function (n) {
                    try {
                        localStorage.setItem(PAGER_KEY, String(n));
                    } catch (e) {}
                };

                let pageSize = readSize();
                let page = 1;
                sizeValEl.textContent = String(pageSize);

                // Visible-to-the-filter set. The pager re-reads this on
                // every refresh so a search/filter change re-slices the
                // page window against the new set without us owning the
                // filter predicate.
                const filterVisible = function () {
                    const out = [];
                    for (let i = 0; i < cards.length; i += 1) {
                        const c = cards[i];
                        if (c.classList.contains("is-hidden")) continue;
                        out.push(c);
                    }
                    return out;
                };

                const applyPager = function () {
                    const vis = filterVisible();
                    const total = vis.length;
                    const totalPages = Math.max(1, Math.ceil(total / pageSize));
                    if (page > totalPages) page = totalPages;
                    if (page < 1) page = 1;
                    const start = (page - 1) * pageSize;
                    const end = start + pageSize;

                    // Reset paged-out, then re-mark the slice that is not
                    // in the current page window. Filter-hiding is layered
                    // on top via .is-hidden (separate concern).
                    for (let i = 0; i < cards.length; i += 1) {
                        cards[i].classList.remove("is-paged-out");
                    }
                    for (let i = 0; i < vis.length; i += 1) {
                        if (i < start || i >= end) {
                            vis[i].classList.add("is-paged-out");
                        }
                    }

                    if (pageEl) pageEl.textContent = String(page);
                    if (totalEl) totalEl.textContent = String(totalPages);
                    prevBtn.disabled = page <= 1;
                    nextBtn.disabled = page >= totalPages;
                    sizeValEl.textContent = String(pageSize);
                };

                prevBtn.addEventListener("click", function () {
                    if (page > 1) {
                        page -= 1;
                        applyPager();
                    }
                });
                nextBtn.addEventListener("click", function () {
                    page += 1;
                    applyPager();
                });
                sizeBtn.addEventListener("click", function () {
                    const i = SIZES.indexOf(pageSize);
                    const next = SIZES[(i + 1) % SIZES.length];
                    pageSize = next;
                    writeSize(pageSize);
                    // Size change always returns to page 1: a smaller page
                    // size can otherwise land the user on an empty page
                    // when total is small, and a larger one feels more
                    // natural from the top.
                    page = 1;
                    applyPager();
                });

                // Filter / search changed: drop to page 1 and re-slice.
                // The filter's `apply()` runs *before* this event fires
                // (it dispatches at the end of apply()), so the
                // filterVisible() read here reflects the new filter set.
                window.addEventListener(
                    "curvoteca:filter-changed",
                    function () {
                        page = 1;
                        applyPager();
                    },
                );

                applyPager();
            })();
        </script>

        <script is:inline>
            (function () {
                const wall = document.getElementById("curve-wall");
                const strip = document.getElementById("tray-strip");
                const empty = document.getElementById("tray-empty");
                const countEl = document.getElementById("tray-count");
                const cmpCountEl = document.getElementById("cmp-count");
                const clearBtn = document.getElementById("tray-clear");
                const railCompare = document.getElementById("rail-compare");
                const app = document.getElementById("app");
                if (!wall || !strip || !empty || !countEl) return;

                let registry = [];
                try {
                    registry = JSON.parse(
                        wall.getAttribute("data-curves") || "[]",
                    );
                } catch (e) {
                    registry = [];
                }
                const byId = {};
                registry.forEach(function (c) {
                    byId[c.id] = c;
                });

                const STORAGE_KEY = window.KEY_COMPARE;
                const PARAM = "c";
                const MAX = 8;
                const TRAY_KEY = window.KEY_TRAY_COLLAPSED;

                const sanitize = function (raw) {
                    if (!raw) return [];
                    return raw
                        .split(",")
                        .map(function (s) {
                            return s.trim();
                        })
                        .filter(function (s) {
                            return /^[a-z0-9][a-z0-9-]*$/.test(s);
                        })
                        .slice(0, MAX);
                };

                const readStore = function () {
                    try {
                        const raw = localStorage.getItem(STORAGE_KEY);
                        if (raw) {
                            const parsed = JSON.parse(raw);
                            if (Array.isArray(parsed))
                                return sanitize(parsed.join(","));
                        }
                    } catch (e) {
                        /* ignore */
                    }
                    return [];
                };

                const writeStore = function (ids) {
                    try {
                        localStorage.setItem(STORAGE_KEY, JSON.stringify(ids));
                    } catch (e) {
                        /* ignore */
                    }
                };

                const readQuery = function () {
                    try {
                        const sp = new URLSearchParams(window.location.search);
                        if (!sp.has(PARAM)) return null;
                        return sanitize(sp.get(PARAM) || "");
                    } catch (e) {
                        return null;
                    }
                };

                const writeQuery = function (ids) {
                    try {
                        const url = new URL(window.location.href);
                        if (ids.length === 0) url.searchParams.delete(PARAM);
                        else url.searchParams.set(PARAM, ids.join(","));
                        window.history.replaceState(null, "", url.toString());
                    } catch (e) {
                        /* ignore */
                    }
                };

                const fromQuery = readQuery();
                const initial = fromQuery !== null ? fromQuery : readStore();
                const state = { ids: initial };

                const buildItem = function (id) {
                    const reg = byId[id];
                    if (!reg) return null;
                    const a = document.createElement("a");
                    a.className = "mini-card tray-item";
                    a.href = "/curve/" + id;
                    a.setAttribute("data-tray-id", id);
                    a.setAttribute("data-tray-name", reg.name);
                    a.title = reg.name + (reg.family ? " / " + reg.family : "");
                    const label = document.createElement("span");
                    label.className = "tray-item-name";
                    label.textContent = reg.name;
                    const wrap = document.createElement("div");
                    wrap.className = "mini-graph curve-view tray-item-graph";
                    wrap.setAttribute("data-curve-view", "");
                    wrap.setAttribute("data-curve-id", id);
                    wrap.setAttribute("data-curve-view-default", "0 0 252 128");
                    wrap.setAttribute(
                        "data-curve-points",
                        JSON.stringify(reg.previewPoints || []),
                    );
                    const canvas = document.createElement("canvas");
                    canvas.className = "curve-view-canvas";
                    canvas.setAttribute("data-curve-canvas", "");
                    canvas.setAttribute("aria-hidden", "true");
                    wrap.appendChild(canvas);
                    const x = document.createElement("button");
                    x.className = "icon tray-item-x";
                    x.type = "button";
                    x.setAttribute("data-tray-remove", id);
                    x.setAttribute("data-label", "x");
                    x.title = "Remove from compare";
                    x.textContent = "x";
                    a.appendChild(label);
                    a.appendChild(wrap);
                    a.appendChild(x);
                    return a;
                };

                const render = function () {
                    strip.innerHTML = "";
                    const ids = state.ids;
                    const tray = document.getElementById("compare-tray");
                    if (ids.length === 0) {
                        // Empty state: show a small "no curves" hint inside the strip
                        // and let the tray-empty element explain the action.
                        empty.classList.remove("is-hidden");
                    } else {
                        ids.forEach(function (id) {
                            const item = buildItem(id);
                            if (item) strip.appendChild(item);
                        });
                        empty.classList.add("is-hidden");
                    }
                    if (tray)
                        tray.classList.toggle("is-empty", ids.length === 0);
                    countEl.textContent = String(ids.length);
                    if (cmpCountEl) {
                        cmpCountEl.textContent = String(ids.length);
                        const statusCmp = document.getElementById("status-cmp");
                        if (statusCmp)
                            statusCmp.classList.toggle("is-on", ids.length > 0);
                    }
                    document.dispatchEvent(
                        new CustomEvent("curvoteca:views-changed"),
                    );
                    document
                        .querySelectorAll("[data-compare-toggle]")
                        .forEach(function (btn) {
                            const id = btn.getAttribute("data-compare-toggle");
                            const on = state.ids.indexOf(id) !== -1;
                            btn.classList.toggle("is-on", on);
                            btn.setAttribute("data-label", on ? "on" : "off");
                            btn.setAttribute(
                                "title",
                                on ? "Remove from compare" : "Add to compare",
                            );
                        });
                };

                const persist = function () {
                    writeStore(state.ids);
                    writeQuery(state.ids);
                };

                const toggle = function (id) {
                    const i = state.ids.indexOf(id);
                    if (i === -1) {
                        if (state.ids.length >= MAX) return;
                        state.ids = state.ids.concat([id]);
                    } else {
                        state.ids = state.ids
                            .slice(0, i)
                            .concat(state.ids.slice(i + 1));
                    }
                    persist();
                    render();
                };

                const readTrayCollapsed = function () {
                    try {
                        return localStorage.getItem(TRAY_KEY) === "1";
                    } catch (e) {
                        return false;
                    }
                };

                const writeTrayCollapsed = function (collapsed) {
                    try {
                        localStorage.setItem(TRAY_KEY, collapsed ? "1" : "0");
                    } catch (e) {
                        /* ignore */
                    }
                };

                const applyTrayCollapsed = function (collapsed) {
                    if (app)
                        app.classList.toggle("is-tray-collapsed", collapsed);
                    if (railCompare) {
                        railCompare.classList.toggle("active", !collapsed);
                        railCompare.setAttribute(
                            "aria-pressed",
                            collapsed ? "false" : "true",
                        );
                        railCompare.title = collapsed
                            ? "show compare"
                            : "hide compare";
                    }
                };

                const focusTray = function () {
                    if (!app) return;
                    app.classList.add("is-tray-focus");
                    const trayEl = document.getElementById("compare-tray");
                    if (trayEl && trayEl.scrollIntoView) {
                        try {
                            trayEl.scrollIntoView({
                                behavior: "smooth",
                                block: "nearest",
                            });
                        } catch (e) {
                            /* ignore */
                        }
                    }
                    const firstItem = strip.querySelector(
                        ".tray-item, .mini-card",
                    );
                    if (firstItem && firstItem.focus) {
                        try {
                            firstItem.focus({ preventScroll: true });
                        } catch (e) {
                            /* ignore */
                        }
                    }
                    setTimeout(function () {
                        app.classList.remove("is-tray-focus");
                    }, 700);
                };

                const toggleTray = function () {
                    const wasCollapsed = !!(
                        app && app.classList.contains("is-tray-collapsed")
                    );
                    const next = !wasCollapsed;
                    applyTrayCollapsed(next);
                    writeTrayCollapsed(next);
                    if (!next) focusTray();
                };

                window.__appClickHandlers.push(function (e) {
                    const tog = e.target.closest("[data-compare-toggle]");
                    if (tog) {
                        e.preventDefault();
                        e.stopPropagation();
                        toggle(tog.getAttribute("data-compare-toggle"));
                        return;
                    }
                    const rem = e.target.closest("[data-tray-remove]");
                    if (rem) {
                        e.preventDefault();
                        e.stopPropagation();
                        toggle(rem.getAttribute("data-tray-remove"));
                        return;
                    }
                    if (e.target.closest("#rail-compare")) {
                        e.preventDefault();
                        toggleTray();
                        return;
                    }
                });

                if (clearBtn) {
                    clearBtn.addEventListener("click", function (e) {
                        e.preventDefault();
                        state.ids = [];
                        persist();
                        render();
                    });
                }

                applyTrayCollapsed(readTrayCollapsed());
                render();
            })();
        </script>

        <script>
            // @ts-nocheck — inline script; intentionally untyped. The renderer
            // module is type-checked at its source.
            import { createCurveCanvasRenderer } from "../lib/curveCanvasRenderer";

            // Gallery + per-curve-view gestures.
            //   - wheel inside wall: step gallery column count
            //   - drag on empty wall: pan the gallery
            //   - drag on [data-curve-view]: zoom X/Y (Houdini-style channel drag)
            //   - Shift+drag on [data-curve-view]: pan the view window
            //   - dblclick a card: focus; Esc: exit focus
            //   - F: fit (reset active view and exit focus)
            //
            // Per-view state shape (persisted):
            //   { zoomX, zoomY, centerX, centerY, wrapMode }
            // - zoomX in [0.25..1]  — zoom OUT only (4x out, see more domain / repeats).
            // - zoomY in [0.5..3]   — tight, normalized (around data range).
            // - center is a fraction of the default viewBox (0..1).
            // - wrapMode drives clamp/repeat/mirror/loop tiling.
        </script>
        <script>
            import {
                clamp,
                parseViewBox,
                fitZoomForPadding,
                VIEWPORT_LIMITS,
                type CurveViewportState,
                type CurveWrapMode,
            } from "../lib/curveViewportMath";
            import { readTokens } from "../lib/renderer/tokens";
            import { createCurveCanvasRenderer } from "../lib/curveCanvasRenderer";

            // Local shapes used by the gallery IIFE. CurveViewportState
            // covers the persisted view shape; the rest are IIFE-internal
            // state that we type here rather than exporting.
            interface ApplyOpts {
                flash?: boolean;
                persist?: boolean;
            }
            interface ModeOpts {
                flash?: boolean;
            }
            interface GridSize {
                minW: number;
                rowH: number;
            }
            interface PanDrag {
                kind: "pan";
                x: number;
                y: number;
                sl: number;
                st: number;
                moved: boolean;
            }
            interface SizeDrag {
                kind: "size";
                x: number;
                y: number;
                minW0: number;
                rowH0: number;
                minWMin0: number;
                minWMax0: number;
                rowHMin0: number;
                rowHMax0: number;
                ratio0: number;
                moved: boolean;
            }
            interface ZoomViewDrag {
                kind: "zoom-view";
                view: HTMLElement;
                id: string;
                x: number;
                y: number;
                zx0: number;
                zy0: number;
                cx0: number;
                cy0: number;
                moved: boolean;
            }
            interface PanViewDrag {
                kind: "pan-view";
                view: HTMLElement;
                id: string;
                x: number;
                y: number;
                zx0: number;
                zy0: number;
                cx0: number;
                cy0: number;
                moved: boolean;
            }
            type DragState = PanDrag | SizeDrag | ZoomViewDrag | PanViewDrag;
            type GalleryMode = "atlas" | "browse" | "focus";
            type Mode = GalleryMode;

            (function () {
                const wall = document.getElementById(
                    "curve-wall",
                ) as HTMLElement | null;
                const grid = document.getElementById(
                    "wall-grid",
                ) as HTMLElement | null;
                const modeEl = document.getElementById(
                    "grid-mode",
                ) as HTMLElement | null;
                const modeLabel = document.getElementById(
                    "grid-mode-label",
                ) as HTMLElement | null;
                if (!wall || !grid || !modeEl || !modeLabel) return;

                const MODE_CLASS: Record<GalleryMode, string> = {
                    atlas: "is-mode-atlas",
                    browse: "is-mode-browse",
                    focus: "is-mode-focus",
                };
                const STEP_MODES: GalleryMode[] = ["atlas", "browse"];
                // Inline Astro scripts don't always pick up env.d.ts, so we
                // coerce the window slot via a typed local to keep the
                // call sites clean.
                interface CurvotecaWindow {
                    KEY_GALLERY_MODE: string;
                    KEY_CURVE_VIEW: string;
                    KEY_WRAP_MODE: string;
                    KEY_GRID_SIZE: string;
                    KEY_GRID_COLS: string;
                    CurvotecaRenderCurveView: (view: HTMLElement) => void;
                }
                const wnd = window as unknown as CurvotecaWindow;
                const MODE_KEY = wnd.KEY_GALLERY_MODE;
                const VIEW_KEY = wnd.KEY_CURVE_VIEW;
                const VIEW_SHARED_ID = "__all";
                const WRAP_KEY = wnd.KEY_WRAP_MODE;
                const VIEW_VERSION = 2;
                // X / Y zoom limits and center clamp are sourced from
                // VIEWPORT_LIMITS in src/lib/curveViewportMath.ts. Edit
                // that file (the top-level VIEWPORT_LIMITS constant) to
                // retune the per-axis ranges.

                const GRID_SIZE_KEY = wnd.KEY_GRID_SIZE;
                const GRID_COLS_KEY = wnd.KEY_GRID_COLS;
                let currentCols = 8; // updated by applyCols; read by GRID_TOKENS
                const GRID_TOKENS = function () {
                    const s = getComputedStyle(grid);
                    const lerp = function (
                        tight: number,
                        loose: number,
                        cols: number,
                    ) {
                        // cols 1..8, 8 = tight, 1 = loose
                        const t = (cols - 1) / 7;
                        return tight + (loose - tight) * t;
                    };
                    const tight = {
                        minWMin: parseFloat(
                            s.getPropertyValue("--card-min-w-min"),
                        ),
                        minWMax: parseFloat(
                            s.getPropertyValue("--card-min-w-max"),
                        ),
                        rowHMin: parseFloat(
                            s.getPropertyValue("--card-row-h-min"),
                        ),
                        rowHMax: parseFloat(
                            s.getPropertyValue("--card-row-h-max"),
                        ),
                    };
                    const loose = {
                        minWMin: parseFloat(
                            s.getPropertyValue("--card-min-w-min-loose"),
                        ),
                        minWMax: parseFloat(
                            s.getPropertyValue("--card-min-w-max-loose"),
                        ),
                        rowHMin: parseFloat(
                            s.getPropertyValue("--card-row-h-min-loose"),
                        ),
                        rowHMax: parseFloat(
                            s.getPropertyValue("--card-row-h-max-loose"),
                        ),
                    };
                    const c = Math.max(1, Math.min(8, currentCols));
                    return {
                        minWMin: lerp(loose.minWMin, tight.minWMin, c),
                        minWMax: lerp(loose.minWMax, tight.minWMax, c),
                        rowHMin: lerp(loose.rowHMin, tight.rowHMin, c),
                        rowHMax: lerp(loose.rowHMax, tight.rowHMax, c),
                        ratio: parseFloat(s.getPropertyValue("--card-ratio")),
                        wheelStep: parseFloat(
                            s.getPropertyValue("--card-wheel-step"),
                        ),
                    };
                };
                const gridSizeFromMode = function (m: string): GridSize {
                    const s = getComputedStyle(grid);
                    return {
                        minW: parseFloat(
                            s.getPropertyValue("--card-" + m + "-w"),
                        ),
                        rowH: parseFloat(
                            s.getPropertyValue("--card-" + m + "-h"),
                        ),
                    };
                };
                const COLS_MIN = 1;
                const COLS_MAX = 8;

                let mode: Mode = "browse";
                let prevMode: Mode = "browse";
                let activeView: HTMLElement | null = null; // most-recently-touched [data-curve-view]
                // --- shared curve-view store --------------------------------
                interface ViewRecord {
                    v: number;
                    zoomX: number;
                    zoomY: number;
                    centerX: number;
                    centerY: number;
                    wrapMode: string;
                }
                const readViewMap = function (): Record<string, ViewRecord> {
                    try {
                        const raw = localStorage.getItem(VIEW_KEY);
                        if (raw) {
                            const p = JSON.parse(raw);
                            if (p && typeof p === "object") return p;
                        }
                    } catch (e) {}
                    return {};
                };
                const writeViewMap = function (
                    map: Record<string, ViewRecord>,
                ) {
                    try {
                        localStorage.setItem(VIEW_KEY, JSON.stringify(map));
                    } catch (e) {}
                };
                const viewMap = readViewMap();
                const readView = function (): CurveViewportState {
                    const v = viewMap[VIEW_SHARED_ID];
                    if (
                        v &&
                        v.v === VIEW_VERSION &&
                        typeof v.zoomX === "number" &&
                        typeof v.zoomY === "number"
                    ) {
                        return {
                            zoomX: clamp(
                                v.zoomX,
                                VIEWPORT_LIMITS.zoomX.min,
                                VIEWPORT_LIMITS.zoomX.max,
                            ),
                            zoomY: clamp(
                                v.zoomY,
                                VIEWPORT_LIMITS.zoomY.min,
                                VIEWPORT_LIMITS.zoomY.max,
                            ),
                            centerX:
                                typeof v.centerX === "number"
                                    ? clamp(
                                          v.centerX,
                                          VIEWPORT_LIMITS.center.min,
                                          VIEWPORT_LIMITS.center.max,
                                      )
                                    : 0.5,
                            centerY:
                                typeof v.centerY === "number"
                                    ? clamp(
                                          v.centerY,
                                          VIEWPORT_LIMITS.center.min,
                                          VIEWPORT_LIMITS.center.max,
                                      )
                                    : 0.5,
                            wrapMode: (v.wrapMode || "clamp") as CurveWrapMode,
                        };
                    }
                    return {
                        zoomX: 1,
                        zoomY: 1,
                        centerX: 0.5,
                        centerY: 0.5,
                        wrapMode: "clamp",
                    };
                };
                const writeViewStore = function (st: CurveViewportState) {
                    viewMap[VIEW_SHARED_ID] = {
                        v: VIEW_VERSION,
                        zoomX: st.zoomX,
                        zoomY: st.zoomY,
                        centerX: st.centerX,
                        centerY: st.centerY,
                        wrapMode: st.wrapMode,
                    };
                    writeViewMap(viewMap);
                };
                const canvasRenderers = new WeakMap();
                const rendererFor = function (view: HTMLElement) {
                    let renderer = canvasRenderers.get(view);
                    if (!renderer) {
                        renderer = createCurveCanvasRenderer(view);
                        renderer.mount(view);
                        canvasRenderers.set(view, renderer);
                    }
                    return renderer;
                };
                // --- viewport visibility ---------------------------------------
                // IntersectionObserver (relative to the wall's scroll container)
                // tells each renderer whether its card is in view. Off-viewport
                // cards skip the per-frame probe + cursor work and strip the
                // probe DOM classes. Re-entry forces a static redraw so the
                // card is correct when scrolled back.
                if (typeof IntersectionObserver !== "undefined") {
                    const viewportObserver = new IntersectionObserver(
                        function (entries) {
                            for (const entry of entries) {
                                // @ts-expect-error - entry.target is EventTarget; we only observe HTMLElements.
                                const view: HTMLElement = entry.target;
                                const renderer = canvasRenderers.get(view);
                                if (renderer) {
                                    renderer.setViewportVisible(
                                        entry.isIntersecting,
                                    );
                                }
                                view.setAttribute(
                                    "data-curve-view-in-viewport",
                                    entry.isIntersecting ? "true" : "false",
                                );
                            }
                        },
                        {
                            root: wall,
                            // Match applyView's bounding-rect cull: any pixel
                            // visible counts. Threshold 0 fires on every
                            // entry/exit transition.
                            rootMargin: "0px",
                            threshold: 0,
                        },
                    );
                    // Observe every view currently in the DOM. New views
                    // (e.g. compare tray additions) are picked up by the
                    // observer on the next mutation; for the static gallery
                    // this covers all of them up front.
                    document
                        .querySelectorAll<HTMLElement>("[data-curve-view]")
                        .forEach(function (view) {
                            viewportObserver.observe(view);
                        });
                }
                wnd.CurvotecaRenderCurveView = function (view: HTMLElement) {
                    if (!view) return;
                    const st = readView();
                    st.wrapMode = wrapMode;
                    applyView(view, st, { persist: false, flash: false });
                };

                // --- grid sizing store --------------------------------------
                const readGridSize = function (): GridSize | null {
                    try {
                        const raw = localStorage.getItem(GRID_SIZE_KEY);
                        if (raw) {
                            const p = JSON.parse(raw);
                            if (
                                p &&
                                typeof p.minW === "number" &&
                                typeof p.rowH === "number"
                            )
                                return p;
                        }
                    } catch (e) {}
                    return null;
                };
                const writeGridSize = function (size: GridSize) {
                    try {
                        localStorage.setItem(
                            GRID_SIZE_KEY,
                            JSON.stringify(size),
                        );
                    } catch (e) {}
                };
                const applyGridSize = function (minW: number, rowH: number) {
                    // Skip if the values are already set on the grid's
                    // inline style. Writing the same value still forces
                    // a style recalc + layout in the browser, which the
                    // pre-paint script + this function would otherwise
                    // do twice on init.
                    const wNext = minW + "px";
                    const hNext = rowH + "px";
                    if (
                        grid.style.getPropertyValue("--card-min-w") === wNext &&
                        grid.style.getPropertyValue("--card-row-h") === hNext
                    )
                        return;
                    grid.style.setProperty("--card-min-w", wNext);
                    grid.style.setProperty("--card-row-h", hNext);
                };
                // Read the active --card-min-w / --card-row-h, falling back
                // to --card-browse-{w,h} if no inline value is set (e.g. before
                // applyGridSize has run for the first time).
                const readActiveSize = function () {
                    const s = getComputedStyle(grid);
                    return {
                        minW:
                            parseFloat(s.getPropertyValue("--card-min-w")) ||
                            parseFloat(s.getPropertyValue("--card-browse-w")),
                        rowH:
                            parseFloat(s.getPropertyValue("--card-row-h")) ||
                            parseFloat(s.getPropertyValue("--card-browse-h")),
                    };
                };
                const setWallHeadGridSize = function (
                    _minW: number,
                    _rowH: number,
                ) {
                    // no-op: the scale readout was removed.
                };

                // --- column count (1..8) ------------------------------------

                // --- column count (1..8) ------------------------------------
                const readCols = function (): number {
                    try {
                        const v = parseInt(
                            localStorage.getItem(GRID_COLS_KEY) || "",
                            10,
                        );
                        if (v >= COLS_MIN && v <= COLS_MAX) return v;
                    } catch (e) {}
                    return 0; // 0 = auto
                };
                const writeCols = function (c: number) {
                    try {
                        if (c <= 0) localStorage.removeItem(GRID_COLS_KEY);
