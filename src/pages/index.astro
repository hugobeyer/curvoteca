                    // style write if the grid already has the same value.
                    // The pre-paint script in <head> sets --grid-cols on
                    // <html> when a value is persisted, and the grid
                    // inherits it; this function would otherwise re-write
                    // the same value and trigger a redundant style+layout.
                    const next =
                        c > 0 ? "repeat(" + c + ", minmax(0, 1fr))" : "";
