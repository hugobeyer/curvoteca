                        "is-mode-atlas",
                        "is-mode-browse",
                        "is-mode-focus",
                    );
                    grid.classList.add(MODE_CLASS[m]);
                    wall.classList.remove(
                        "is-mode-atlas",
                        "is-mode-browse",
                        "is-mode-focus",
