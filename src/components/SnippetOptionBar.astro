---
const options = [
    "constants",
    "clamp",
    "fit",
    "function",
    "comments",
    "uniforms",
] as const;
---

<div
    class="chips snippet-option-bar"
    aria-label="Snippet options"
    data-snippet-bar
>
    {
        options.map((option) => (
            <button
                class="chip snippet-option"
                type="button"
                data-snippet-option-key={option}
                aria-pressed="false"
                disabled
                aria-disabled="true"
                title={`Toggle ${option}`}
            >
                {option}
            </button>
        ))
    }
</div>

<script is:inline>
    (function () {
        const host = document.querySelector("[data-snippet-bar]");
        if (!host) return;
        const buttons = host.querySelectorAll("[data-snippet-option-key]");
        let available = {};
        let active = {};

        const emit = function () {
            host.dispatchEvent(
                new CustomEvent("curvoteca:snippet-options-change", {
                    bubbles: true,
                    detail: { active: active, available: available },
                }),
            );
        };

        const syncButtons = function () {
            buttons.forEach(function (btn) {
                const key = btn.getAttribute("data-snippet-option-key");
                const enabled = !!available[key];
                btn.disabled = !enabled;
                btn.setAttribute("aria-disabled", enabled ? "false" : "true");
                if (!enabled) active[key] = false;
                btn.classList.toggle("active", !!active[key] && enabled);
                btn.setAttribute(
                    "aria-pressed",
                    !!active[key] && enabled ? "true" : "false",
                );
            });
        };

        const apply = function (resetActive) {
            const raw = host.getAttribute("data-snippet-options");
            available = {};
            try {
                available = raw ? JSON.parse(raw) : {};
            } catch (err) {
                available = {};
            }
            if (!available || typeof available !== "object") available = {};
            if (resetActive) active = {};
            syncButtons();
            emit();
        };

        buttons.forEach(function (btn) {
            btn.addEventListener("click", function () {
                const key = btn.getAttribute("data-snippet-option-key");
                if (!key || btn.disabled || !available[key]) return;
                active[key] = !active[key];
                syncButtons();
                emit();
            });
        });

        apply(true);
        new MutationObserver(apply).observe(host, {
            attributes: true,
            attributeFilter: ["data-snippet-options", "data-snippet-curve-id"],
        });
    })();
</script>
