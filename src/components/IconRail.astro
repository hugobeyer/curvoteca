---
import StarIcon from "./StarIcon.astro";
import GalleryIcon from "./GalleryIcon.astro";
import DonateIcon from "./DonateIcon.astro";
import InfoIcon from "./InfoIcon.astro";
import SvgFilters from "./SvgFilters.astro";
import RailAd from "./RailAd.astro";
import adsData from "../data/ads.json";
import type { AdEntry } from "../data/ads";

interface AdsData {
    slots?: { "rail-bottom"?: { enabled?: boolean; adIds?: string[] } };
    ads?: AdEntry[];
}

const data = adsData as unknown as AdsData;
const railBottomSlot = data.slots?.["rail-bottom"];
const showRailAds = railBottomSlot?.enabled;
const railAdIds = railBottomSlot?.adIds ?? [];
const railAds = railAdIds
    .map((id) => data.ads?.find((a) => a.id === id && a.active) ?? null)
    .filter((a): a is AdEntry => a !== null)
    .slice(0, 3);
---

<SvgFilters />

<nav class="rail" id="icon-rail" aria-label="Icon navigation">
    <a
        href="/"
        class="icon"
        data-rail-view="gallery"
        title="Gallery"
        aria-label="Gallery"
    >
        <GalleryIcon size={20} class="is-gallery" />
        <span class="rail-label">Gallery</span>
    </a>
    <button
        class="icon"
        type="button"
        data-fav-filter
        data-rail-fav
        disabled
        title="Favorites"
        aria-label="Toggle favorites filter"
    >
        <StarIcon size={20} class="is-star" />
        <span class="rail-label">Favorites</span>
    </button>
    <button
        class="icon"
        type="button"
        disabled
        title="Work in progress"
        aria-label="Snippets (work in progress)"
    >
        <span class="rail-glyph" aria-hidden="true">{}</span>
        <span class="rail-label">Snippets</span>
    </button>
    <button
        class="icon"
        type="button"
        disabled
        title="Work in progress"
        aria-label="Shader (work in progress)"
    >
        <span class="rail-glyph" aria-hidden="true">fx</span>
        <span class="rail-label">Shader</span>
    </button>
    <button
        class="icon"
        type="button"
        data-rail-view="sponsor"
        title="Sponsor"
        aria-label="Support Curvoteca"
    >
        <DonateIcon size={20} class="is-donate" />
        <span class="rail-label">Sponsor</span>
    </button>
    <button
        class="icon"
        type="button"
        data-rail-view="about"
        title="About"
        aria-label="About Curvoteca"
    >
        <InfoIcon size={20} class="is-info" />
        <span class="rail-label">About</span>
    </button>
    {
        showRailAds && railAds.length > 0 && (
            <div class="rail-ad-row">
                {railAds.map((ad) => (
                    <RailAd ad={ad} />
                ))}
            </div>
        )
    }
</nav>

<style>
    .rail-ad-row {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-top: auto;
        padding: 4px 0 0;
    }
</style>
