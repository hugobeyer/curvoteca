---
import CurveViewport from "./CurveViewport.astro";
import TargetIcon from "./TargetIcon.astro";
import StarIcon from "./StarIcon.astro";
import CopyIcon from "./CopyIcon.astro";
import ExpandIcon from "./ExpandIcon.astro";
import { buildSearchHaystack } from "../lib/searchIndex";
import type { CurveDefinition } from "../data/curves";

interface Props {
    curve: CurveDefinition;
}

const { curve } = Astro.props as Props;

const haystack = buildSearchHaystack(curve);
const family = curve.family;
const tags = curve.tags.join(" ");
const useCases = curve.useCases.join(" ");
const targets = Object.keys(curve.snippets ?? {}).join(" ");
const equation = curve.snippets?.equation ?? curve.formula;
const curveLabel = [curve.family, curve.continuity].filter(Boolean).join(" / ");

const snippetsJson = JSON.stringify(curve.snippets ?? {});
---

<article
    class="card"
    data-curve-id={curve.id}
    data-search={haystack}
    data-family={family}
    data-tags={tags}
    data-usecases={useCases}
    data-targets={targets}
    title="RMB opens context actions: copy, paste, compare, pin"
>
    <header class="card-head">
        <span class="card-title">{curve.name}</span>

        <div class="actions" aria-label="Icon actions">
            <span class="action">
                <button
                    class="icon copy-btn"
                    data-copy-toggle
                    data-snippets={snippetsJson}
                    title="Copy snippet"
                    type="button"
                >
                    <CopyIcon size={16} />
                </button>
            </span>

            <span class="action">
                <button
                    class="icon fav-btn"
                    title="favorite"
                    type="button"
                    data-fav-toggle={curve.id}
                    data-label="*"
                >
                    <StarIcon size={12} />
                </button>
            </span>
            <span class="action">
                <button
                    class="icon compare-btn"
                    title="Add to workbench"
                    type="button"
                    data-compare-toggle={curve.id}
                    data-label="off"
                    aria-label={`Add ${curve.name} to workbench`}
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        height="20px"
                        viewBox="0 -960 960 960"
                        width="20px"
                        fill="currentColor"
                        aria-hidden="true"
                    >
                        <path d="M480-144 144-408l58-46 278 218 278-218 58 46-336 264Zm0-192L144-600l336-264 336 264-336 264Zm0-258Zm0 166 219-172-219-172-219 172 219 172Z" />
                    </svg>
                </button>
            </span>
            <span class="action">
                <button
                    class="icon view-cycle-btn"
                    title="Cycle view"
                    type="button"
                    data-view-cycle={curve.id}
                    aria-label={`Cycle ${curve.name} view`}
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        height="20px"
                        viewBox="0 -960 960 960"
                        width="20px"
                        fill="currentColor"
                        aria-hidden="true"
                    >
                        <path d="M192-240v-72h576v72H192Zm0-144v-72h576v72H192Zm0-144v-84l216-132 180 128.38L768-744v88.2L588-528 405.3-657.6 192-528Z" />
                    </svg>
                </button>
            </span>
            <span class="action">
                <button
                    class="icon info-btn"
                    type="button"
                    data-open-detail={curve.id}
                    title="Open detail"
                    aria-label={`Open ${curve.name} detail`}
                >
                    <ExpandIcon size={16} />
                </button>
            </span>
        </div>
    </header>
    <CurveViewport curve={curve} showReadout={true} />
    <div class="meta" aria-hidden="true">
        <span class="meta-summary">{curveLabel}</span>
    </div>
</article>
