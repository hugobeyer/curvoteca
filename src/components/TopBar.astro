---
import sponsorsData from "../data/sponsors.json";

interface SponsorEntry {
    id: string;
    name: string;
    label: string;
    description: string;
    url: string;
    active: boolean;
}
interface SponsorsData {
    slots: { topbar?: { enabled?: boolean; sponsorId?: string | null } };
    sponsors: SponsorEntry[];
}
const data = sponsorsData as unknown as SponsorsData;

const topbarSlot = data.slots?.topbar;
const showTopbarSponsor = topbarSlot?.enabled;
const topbarSponsor = topbarSlot?.sponsorId
    ? (data.sponsors.find((s) => s.id === topbarSlot.sponsorId && s.active) ??
      null)
    : null;

const headLabel = topbarSponsor ? topbarSponsor.label : "Sponsor";
---

<header class="bar" id="curve-bar">
    <div class="bar-cell bar-cell--brand">
        <a class="brand" href="/" aria-label="Curvoteca home">
            <img class="brand-logo" src="/logo.svg" alt="" />
        </a>
    </div>
    <div class="bar-cell bar-cell--sponsor tools">
        <img class="sponsor-logo" src="/logo.svg" alt="" />
        {
            showTopbarSponsor &&
                (topbarSponsor ? (
                    <a
                        class="sponsor-btn"
                        href={topbarSponsor.url}
                        target="_blank"
                        rel="sponsored nofollow noopener noreferrer"
                        title={topbarSponsor.description}
                    >
                        Supported by {topbarSponsor.name}
                    </a>
                ) : (
                    <button
                        class="sponsor-btn"
                        type="button"
                        data-rail-view="sponsor"
                    >
                        Sponsor this slot
                    </button>
                ))
        }
    </div>
</header>

<style>
    :global(.bar:has(.tools)) {
        grid-template-columns: auto 1fr 33%;
        align-items: stretch;
        padding: 0;
        gap: 0;
        height: var(--topbar-height);
    }
    .bar-cell {
        display: flex;
        align-items: center;
        min-width: 0;
    }
    .bar-cell--brand {
        justify-content: flex-start;
        padding: 0 6px;
    }
    .bar-cell--brand .brand {
        height: 100%;
        display: flex;
        align-items: center;
    }
    .brand-logo {
        height: var(--topbar-logo-h);
        width: auto;
        display: block;
    }
    .bar-cell--sponsor {
        justify-content: flex-end;
        grid-column: 3;
        align-items: center;
        align-self: stretch;
        width: 100%;
        max-width: none;
        --layer-title: var(--text-card);
        background:
            var(--layer-body, none), var(--card-bg-gradient), var(--panel2);
        border-radius: var(--pill-radius);
        padding: 0 12px;
        margin: 0 6px 0 0;
    }
    .sponsor-logo {
        height: var(--topbar-sponsor-logo-h);
        width: auto;
        display: block;
    }
    .tools {
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-width: 0;
        height: 100%;
        padding-right: 8px;
    }
    .sponsor-btn {
        height: 28px;
        padding: 0 12px;
        border: 0;
        border-radius: var(--pill-radius);
        background: color-mix(in srgb, var(--white) 6%, transparent);
        color: var(--muted);
        font-family: var(--font-family);
        font-size: var(--font-size-xs);
        font-weight: var(--font-weight-medium);
        letter-spacing: var(--letter-spacing-wide);
        text-transform: var(--text-transform-uppercase);
        cursor: pointer;
        transition:
            background 0.12s ease,
            color 0.12s ease;
    }
    .sponsor-btn:hover {
        background: color-mix(in srgb, var(--accent) 18%, transparent);
        color: var(--white);
    }
</style>
